<script>
<name>!lib.ship.set.trader.signal.attacked</name>
<version>1</version>
<engineversion>73</engineversion>
<description>task to set trader attacked behaviour</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
@ = wait 1000 ms
  do if [OWNER] == Player
    return null
  gosub sub.SetSignal
@ = wait 10000 ms
  gosub sub.SetSignal
  return null
  
  sub.SetSignal:
  $command = [THIS] -> get command
  if $command == COMMAND_FREETRADER
    [THIS] ->connect ship command/signal SIGNAL_ATTACKED to script !lib.interrupt with prio 10
    [THIS] ->add secondary signal: signal=SIGNAL_ATTACKED, script=!ship.signal.attacked.ts, prio=100, name='trader.npc.attacked'
    return null
  end
  endsub
  
  return null
]]>
</sourceplaintext>
