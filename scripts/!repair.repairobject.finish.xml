<script>
<name>!repair.repairobject.finish</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Cleanup after finishing repairing</description>
<arguments>
<argument index="1" name="victim" type="Var/Ship/Station" desc="" />
</arguments>
<sourceplaintext>
<![CDATA[
  $local = [THIS] -> get local variable: name='repair-original-race'
  if $local
    [THIS] ->set owner race to $local
    [THIS] ->set local variable: name='repair-original-race' value=null
  end
  
  [THIS] ->set local variable: name='last-repair-hit' value=null
  [THIS] ->ignore collisions: [FALSE]
  [THIS] ->set attack target to null
  set script command target: null
  
  $tasks = [THIS] ->get all tasks with script on stack=!move.movetoposition
  gosub sub.EndTasks
  $tasks = [THIS] ->get all tasks with script on stack=!move.movetostation
  gosub sub.EndTasks
  
  skip if $victim
    return null
  [THIS] ->remove secondary signal: signal=SIGNAL_KILLED, name='Repair.Signal'
  skip if $victim -> exists
    return null
  
  $hull = $victim -> get hull
  $hullMax = $victim -> get max hull
  if $hull == $hullMax
    $victim ->set local variable: name='repairers' value=null
    $victim ->remove secondary signal: signal=SIGNAL_REPAIRED, name='Repair.Signal'
  else
    $repairers = $victim -> get local variable: name='repairers'
    find and remove: [THIS] from array $repairers
    if size of array $repairers
      $victim ->set local variable: name='repairers' value=$repairers
    else
      $victim ->set local variable: name='repairers' value=null
      $victim ->remove secondary signal: signal=SIGNAL_REPAIRED, name='Repair.Signal'
    end
@   = [THIS] -> call script debug.printdata.array :  Data Array=$repairers  File ID=9898  Tab=''
  end
  
  return null
  
  * =============================
  * End movetostation and movetoposition tasks
  * =============================
  sub.EndTasks:
  $n = size of array $tasks
  while $n
    dec $n = 
    $task = $tasks[$n]
    skip if $task == 0
      [THIS] ->start task $task with script !lib.interrupt and prio 100: arg1=null arg2=null arg3=null arg4=null arg5=null
  end
  endsub
  return null
]]>
</sourceplaintext>
