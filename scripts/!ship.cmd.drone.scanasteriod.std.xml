<script>
<name>!ship.cmd.drone.scanasteriod.std</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Drone Carrier  Command: Scan asterods</description>
<arguments>
<argument index="1" name="a.sector" type="Var/Sector" desc="Sector" />
</arguments>
<sourceplaintext>
<![CDATA[
  * make sure we can actually get there
  if [SECTOR] != $a.sector
    $gate = get next gate on route from [SECTOR] to $a.sector
    skip if $gate -> exists
      return null
  end
  
  [THIS] ->set command: COMMAND_DRONE_SCANASTEROID
  [THIS] ->set destination to $a.sector
  
  * move to target sector
  while [SECTOR] != $a.sector
@   = [THIS] -> call script !move.movetosector :  sector=$a.sector
@   = wait 500 ms
  end
  
  $asteroids = [SECTOR] -> get asteroid array from sector
  skip if $asteroids
    return null
  
  skip if size of array $asteroids
    return null
  
  $doingAsteroids = table alloc
  
  while size of array $asteroids
@   = [THIS] -> call script !lib.carrier.recallidle : 
@   = wait 1000 ms
    
    $i = size of array $asteroids
    while $i
@     = wait 50 ms
      dec $i = 
      $a = $asteroids[$i]
  * remove any already scanned
      if $a -> is asteroid scanned
        remove element from array $asteroids at index $i
        continue
      end
      if not $a -> is known
        remove element from array $asteroids at index $i
        continue
      end
      
  * already sent a ship?
      if $doingAsteroids[$a]
        $drone = $doingAsteroids[$a]
        if not $drone -> exists
          remove key $a from table $doingAsteroids
@       else if [THIS] -> call script !lib.carrier.isshipbusy :  Ship=$drone  Allow Recall=[TRUE]
          continue
        else
          remove key $a from table $doingAsteroids
        end
      end
      
  * now pick a drone to send
      gosub sub.GetDrone
      if $drone -> exists
        $droneCode = $drone -> get ID code
        START $drone -> command COMMAND_SCAN_ASTEROID : arg1=$a, arg2=1, arg3=[SECTOR], arg4=null
        $doingAsteroids[$a] = $drone
      end
    end
    
  end
  
@ = [THIS] -> call script !lib.carrier.recallidle : 
  return null
  
  sub.GetDrone:
  $drone = null
  $aDrones = [THIS] ->get managed ships: role=Drone
  $j = size of array $aDrones
  while $j
    dec $j = 
    $d = $aDrones[$j]
@   do if [THIS] -> call script !lib.carrier.isshipbusy :  Ship=$d  Allow Recall=[TRUE]
      continue
    $drone = $d
    break
  end
  endsub
  return null
]]>
</sourceplaintext>
