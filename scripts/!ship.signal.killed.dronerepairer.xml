<script>
<name>!ship.signal.killed.dronerepairer</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Remove local var from repair target</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  $victim = get script command target
  if not $victim
    $victim = [THIS] -> get attack target
    if not $victim
@     = [THIS] -> call script plugin.jj.lib.log.object :  prepend='No script command target'  logFile=9898
      return null
    end
  end
  skip if $victim -> exists
    return null
  
  $repairers = $victim -> get local variable: name='repairers'
  skip if $repairers
    return null
  
  find and remove: [THIS] from array $repairers
  if size of array $repairers
    $victim ->set local variable: name='repairers' value=$repairers
  else
    $victim ->set local variable: name='repairers' value=null
    $victim ->remove secondary signal: signal=SIGNAL_REPAIRED, name='Repair.Signal'
  end
@ = [THIS] -> call script plugin.jj.lib.log.object :  prepend='Drone repairer signal killed'  logFile=9898
@ = [THIS] -> call script debug.printdata.array :  Data Array=$repairers  File ID=9898  Tab=''
  return null
]]>
</sourceplaintext>
