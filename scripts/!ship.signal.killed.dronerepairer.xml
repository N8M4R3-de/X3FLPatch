<script>
<name>!ship.signal.killed.dronerepairer</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Remove local var from repair target</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  $victim = get script command target
  if not $victim
    $victim = [THIS] -> get attack target
    skip if $victim
      return null
  end
  skip if $victim -> exists
    return null
  
  $repairers = $victim -> get local variable: name='ships.repairers'
  skip if $repairers
    return null
  
  find and remove: [THIS] from array $repairers
  if size of array $repairers
    $victim ->set local variable: name='ships.repairers' value=$repairers
  else
    $victim ->set local variable: name='ships.repairers' value=null
    $victim ->remove secondary signal: signal=SIGNAL_REPAIRED, name='Repair.Signal'
  end
  
  return null
]]>
</sourceplaintext>
