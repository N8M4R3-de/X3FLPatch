<script>
<name>!move.explore.waypoints</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Move ships to way points to explore (Map Sector)</description>
<arguments>
<argument index="1" name="a.sector" type="Var/Sector" desc="Sector" />
<argument index="2" name="a.waypoints" type="Value" desc="Waypoints" />
</arguments>
<sourceplaintext>
<![CDATA[
  skip if $a.waypoints
    return null
  
  skip if is datatype[ $a.waypoints ] == DATATYPE_ARRAY
    return null
  
  skip if size of array $a.waypoints
    return null
  
  [THIS] ->set command: COMMAND_EXPLORE_SECTOR
  [THIS] ->set destination to $a.sector
  
  while [SECTOR] != $a.sector
@   = [THIS] -> call script !move.movetosector :  sector=$a.sector
@   = wait 100 ms
  end
  
  do if [OWNER] == Player
    [THIS] ->start task [Task.Explore] with script !lib.ext.mapsector and prio 80: arg1=1 arg2=null arg3=null arg4=null arg5=null
  
  $max = size of array $a.waypoints
  $i = 0
  while $i < $max
    $position = $a.waypoints[$i]
    $x = $position[0]
    $y = $position[1]
    $z = $position[2]
    
@   = [THIS] -> call script !move.movetoposition :  sector=$a.sector  position x=$x  position y=$y  position z=$z  precision=1000
    do if [OWNER] == Player
@     = [THIS] -> call script !lib.ext.mapsector :  Loop=0
    inc $i = 
  end
  
  do if [OWNER] == Player
    [THIS] ->start task [Task.Explore] with script !lib.interrupt and prio 100: arg1=null arg2=null arg3=null arg4=null arg5=null
  
  return null
]]>
</sourceplaintext>
