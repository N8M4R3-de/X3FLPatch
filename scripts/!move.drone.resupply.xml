<script>
<name>!move.drone.resupply</name>
<version>2</version>
<engineversion>73</engineversion>
<description>Send drone to resupply</description>
<arguments>
<argument index="1" name="a.wares" type="Value" desc="Ware Table" />
<argument index="2" name="a.target" type="Var/Ship/Station" desc="Target" />
</arguments>
<sourceplaintext>
<![CDATA[
  skip if $a.wares
    return null
  skip if $a.target
    return null
  
  [THIS] ->set command: COMMAND_RESUPPLY
  [THIS] ->set destination to $a.target
  
  do if [THIS] -> is docked
@   = [THIS] -> call script !move.undock : 
  
  while not [THIS] -> is in same sector as $a.target
    $target.sector = $a.target -> get sector
@   = [THIS] -> call script !move.movetosector :  sector=$target.sector
@   = wait 500 ms
  end
  
  if [THIS] -> get amount of ware Transporter Device in cargo bay
    while not [THIS] -> is in transporter range: ship=$a.target
@     = wait 200 ms
      $range = get transporter range
      $range = $range * 2 / 3
      $x = $a.target -> get x position
      $y = $a.target -> get y position
      $z = $a.target -> get z position
@     = [THIS] -> call script !move.movetopositioncontinue :  sector=$target.sector  position x=$x  position y=$y  position z=$z  precision=$range
      skip if $a.target -> exists
        return null
    end
  * Transfer wares from drone to target
    $ware = get next key: table=$a.wares key=null
    while $ware
      $amt = $a.wares[$ware]
      $loaded = $a.target -> add $amt units of $ware
      $loaded = - $loaded
      = [THIS] -> add $loaded units of $ware
      
      $ware = get next key: table=$a.wares key=$ware
    end
    return null
  end
  
  skip if $a.target -> is docking possible of [THIS]
    return null
  skip if [THIS] -> is docking allowed at $a.target
    return null
  
  while not [THIS] -> is docked
@   = [THIS] -> call script !move.movetostation :  station=$a.target
@   = wait 500 ms
    skip if $a.target -> exists
      return null
  end
  
  $ware = get next key: table=$a.wares key=null
  while $ware
    $amt = $a.wares[$ware]
    = [THIS] -> unload $amt units of $ware
    $ware = get next key: table=$a.wares key=$ware
  end
  
  return null
  
]]>
</sourceplaintext>
