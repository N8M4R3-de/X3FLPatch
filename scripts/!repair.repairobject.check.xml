<script>
<name>!repair.repairobject.check</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Watch for end of !repair.repairobject and reenable collision</description>
<arguments>
<argument index="1" name="victim" type="Var/Ship/Station" desc="" />
<argument index="2" name="isStationary" type="Var/Boolean" desc="" />
</arguments>
<sourceplaintext>
<![CDATA[
@ = wait 100 ms
  while [THIS] -> is script !repair.repairobject on stack of task=0
@   = wait 4000 ms
  end
  skip if $isStationary
    $victim = null
@ = [THIS] -> call script !repair.repairobject.finish :  =$victim
@ = [THIS] -> call script plugin.jj.lib.log.object :  prepend='Finishing up !repair.repairobject.check'  logFile=9898
  
  if [THIS] -> is in active sector
    while $victim -> exists
  * Give ship a chance to escape without faceplanting into station
      $distVertex = [THIS] ->get distance in active sector to nearest vertex: object=$victim
      do if $distVertex > 1000
        break
      [THIS] ->ignore collisions: [TRUE]
@     = wait 6000 ms
    end
  end
  [THIS] ->ignore collisions: [FALSE]
  
  return null
]]>
</sourceplaintext>
