<script>
<name>!lib.get.examples.from.objects</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Returns examples of each type found in an array of objects</description>
<arguments>
<argument index="1" name="objects" type="Var/Array" desc="" />
</arguments>
<sourceplaintext>
<![CDATA[
  skip if $objects
    return null
  $i = size of array $objects
  skip if $i
    return null
  $examples = array alloc: size=0
  while $i
    dec $i = 
    $object = $objects[$i]
    $mainType = $object -> get maintype
    $subType = $object -> get subtype
    $alreadyRepresented = [FALSE]
    $j = size of array $examples
    while $j
      dec $j = 
      $example = $examples[$j]
      $mainType2 = $example -> get maintype
      $subType2 = $example -> get subtype
      if $mainType == $mainType2 AND $subType == $subType2
        $alreadyRepresented = [TRUE]
        break
      end
    end
    skip if $alreadyRepresented
      append $object to array $examples
  end
  return $examples
]]>
</sourceplaintext>
