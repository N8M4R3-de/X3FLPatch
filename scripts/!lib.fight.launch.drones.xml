<script>
<name>!lib.fight.launch.drones</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Launch fighter drones if they weren't launched recently</description>
<arguments>
<argument index="1" name="attacker" type="Var/Ship/Station" desc="" />
<argument index="2" name="min" type="Var/Number" desc="" />
<argument index="3" name="max" type="Var/Number" desc="" />
</arguments>
<sourceplaintext>
<![CDATA[
  if [OWNER] == Player
    skip if [THIS] ->get should drop drones
      return null
  end
  $drone.time = [THIS] -> get local variable: name='drop.drones'
  $time = playing time
  do if $drone.time AND $time <= ( $drone.time + 180 )
    return null
  [THIS] ->set local variable: name='drop.drones' value=null
  $rnd = random value from $min to $max - 1
  do if [THIS] -> launch $rnd fight drones: protect me or attack target=$attacker
    [THIS] ->set local variable: name='drop.drones' value=$time
  return null
]]>
</sourceplaintext>
