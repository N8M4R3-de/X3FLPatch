<line indent="&#160;&#160;"><text>return&#160;</text><var>null</var></line>
<line indent=""><text>end</text></line>
<line indent=""><var>$drone.time&#160;=&#160;</var><var>[THIS]&#160;-&gt;</var><text>&#160;get&#160;local&#160;variable:&#160;name=</text><var>'drop.drones'</var></line>
<line indent=""><var>$time&#160;=&#160;</var><text>playing&#160;time</text></line>
<line indent=""><var>do&#160;if&#160;</var><var>$drone.time</var><text>&#160;</text><var>AND</var><text>&#160;</text><var>$time</var><text>&#160;</text><var>&lt;=</var><text>&#160;</text><var>(</var><text>&#160;</text><var>$drone.time</var><text>&#160;</text><var>+</var><text>&#160;</text><var>180</var><text>&#160;</text><var>)</var></line>
<line indent="&#160;"><text>return&#160;</text><var>null</var></line>
<line indent=""><var>[THIS]&#160;-&gt;</var><text>set&#160;local&#160;variable:&#160;name=</text><var>'drop.drones'</var><text>&#160;value=</text><var>null</var></line>
<line indent=""><var>$rnd&#160;=&#160;</var><text>random&#160;value&#160;from&#160;</text><var>$min</var><text>&#160;to&#160;</text><var>$max</var><text>&#160;-&#160;1</text></line>
<line indent=""><var>do&#160;if&#160;</var><var>[THIS]&#160;-&gt;</var><text>&#160;launch&#160;</text><var>$rnd</var><text>&#160;fight&#160;drones:&#160;protect&#160;me&#160;or&#160;attack&#160;target=</text><var>$attacker</var></line>
