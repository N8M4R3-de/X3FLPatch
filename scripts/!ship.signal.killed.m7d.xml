<script>
<name>!ship.signal.killed.m7d</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Order managed drones to destroy themselves</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  * M7D killed, so we should retire the drones.
  do if [OWNER] == Player
    return null
  [THIS] ->set local variable: name='signal_killed' value=[TRUE]
  $drones = [THIS] ->get managed ships: role=Drone
  $i = size of array $drones
  while $i
    dec $i = 
    $drone = $drones[$i]
    skip if $drone -> exists
      continue
    START $drone -> command COMMAND_DESTROY_THIS : arg1=null, arg2=null, arg3=null, arg4=null
  end
  return null
]]>
</sourceplaintext>
