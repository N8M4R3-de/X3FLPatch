<script>
<name>lib.rotateobject</name>
<version>2</version>
<engineversion>73</engineversion>
<description>Rotate an object to face another</description>
<arguments>
<argument index="1" name="a.obj1" type="Value" desc="Object 1" />
<argument index="2" name="a.obj2" type="Value" desc="Object 2" />
<argument index="3" name="a.offset" type="Value" desc="Offset Rotation" />
<argument index="4" name="a.smooth" type="Var/Boolean" desc="Rotate Obj1 Smoothly" />
</arguments>
<sourceplaintext>
<![CDATA[
  skip if $a.obj1
    return null
  skip if $a.obj2
    return null
  
@ $dir = [THIS] -> call script lib.math.getdirectionvector :  Object 1=$a.obj2  Object 2=$a.obj1
  
  $x = $dir[0]
  $y = $dir[1]
  $z = $dir[2]
  $angles = get angles from vector: x=$x, y=$y, z=$z
  $alpha = $angles[0]
  $beta = $angles[1]
  $gamma = $angles[2]
  
  if $a.offset
    $rot = $alpha
    $offset = $a.offset[0]
    gosub sub.Offset
    $alpha = $rot
    
    $rot = $beta
    $offset = $a.offset[1]
    gosub sub.Offset
    $beta = $rot
    
    $rot = $gamma
    $offset = $a.offset[2]
    gosub sub.Offset
    $gamma = $rot
  end
  if $a.smooth
    if $a.obj1 -> is in active sector
@     = [THIS] -> call script lib.rotateobject.smooth :  =$alpha  =$beta  =$gamma
      return null
    end
  end
  $a.obj1 ->set rotation: alpha=$alpha beta=$beta gamma=$gamma
  return null
  * =================
  sub.Offset:
  if $offset
    $rot = $rot + $offset
    if $rot > 65536
      $rot = $rot - 65536
    else if $rot < 0
      $rot = $rot + 65536
    end
    endsub
  end
  $offset = 0
  endsub
  
  return null
]]>
</sourceplaintext>
