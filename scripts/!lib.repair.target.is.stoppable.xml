<sourceplaintext>
<![CDATA[
  skip if [THIS] -> is of class Moveable Ship
    return [FALSE]
  do if [THIS] -> is $repairer a enemy
    return [FALSE]
  if [OWNER] == Player
    $race = $repairer -> get owner race
    skip if $race == Player
      return [FALSE]
    do if [THIS] == [PLAYERSHIP]
      return [FALSE]
  end
  return [TRUE]
]]>
</sourceplaintext>
