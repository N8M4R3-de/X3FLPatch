<script>
<name>!ship.cmd.drone.scanships</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Ship Command: Drone carrier, scan ships</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  [THIS] ->set command: COMMAND_DRONE_SCANSHIPS
  
  $shipsBeingScanned = table alloc
  $shipsToScan = array alloc: size=0
  
  $nearbySectors = [SECTOR] -> find all sectors within 1 jumps: Only known sectors=[TRUE]
  
  while [TRUE]
@   = [THIS] -> call script !lib.carrier.recallidle : 
@   = wait 5000 ms
    
    gosub sub.GetDrones
    skip if $aDrones
      continue
    
    gosub sub.GetShips
    
  * Check ships currently being chased are still nearby. Remove if not. "Nearby" means the ship is still in the sector or an adjacent sector and not docked.
    gosub sub.checkShipsBeingScanned
    
    $i = size of array $aDrones
    while $i
      dec $i = 
      $drone = $aDrones[$i]
      
      skip if size of array $shipsToScan
        break
      
      $ret.Ship = $shipsToScan[0]
      if $ret.Ship -> exists
        $shipsBeingScanned[$ret.Ship] = $drone
        START $drone -> command COMMAND_SCANSHIP : arg1=$ret.Ship, arg2=null, arg3=null, arg4=null
      end
      remove element from array $shipsToScan at index 0
    end
  end
  
  return null
  
  * ==============================
  
  sub.GetDrones:
  $aDrones = [THIS] ->get managed ships: role=Drone
  if $aDrones
    $i = size of array $aDrones
    while $i
      dec $i = 
      $drone = $aDrones[$i]
      if not $drone -> get amount of ware Freight Scanner in cargo bay
        remove element from array $aDrones at index $i
        continue
      end
@     if [THIS] -> call script !lib.carrier.isshipbusy :  Ship=$drone  Allow Recall=[TRUE]
        remove element from array $aDrones at index $i
        continue
      end
    end
  end
  endsub
  
  * ==============================
  
  sub.GetShips:
  if not size of array $shipsToScan
    $aShips = [SECTOR] -> get ship array from sector/ship/station
    if $aShips
      
      $j = size of array $aShips
      while $j
        dec $j = 
        $ship = $aShips[$j]
        
        do if $shipsBeingScanned[$ship]
          continue
        skip if $ship -> is known
          continue
        skip if $ship -> is of class Moveable Ship
          continue
        $ship.owner = $ship -> get true owner
        do if $ship.owner == [OWNER]
          continue
        do if $ship ->is cargo visible
          continue
        append $ship to array $shipsToScan
        
      end
    end
  end
  endsub
  
  * ==============================
  
  sub.checkShipsBeingScanned:
  
  $ship = get next key: table=$shipsBeingScanned key=null
  while $ship
    
    $drone = $shipsBeingScanned[$ship]
    if not $drone -> exists
      remove key $ship from table $shipsBeingScanned
      $ship = get next key: table=$shipsBeingScanned key=null
      continue
    end
    
    if not $ship -> exists
      gosub sub.recallDrone
      continue
    end
    
    $cmd = $drone -> get command
    if $cmd != COMMAND_SCANSHIP
      gosub sub.recallDrone
      continue
    end
    
    $env = $ship -> get environment
    if $env != [SECTOR]
      if $ship -> is docked
        gosub sub.recallDrone
        continue
      end
      
      $sector = $ship -> get sector
      if not find $sector in array: $nearbySectors
        gosub sub.recallDrone
        continue
      end
    end
    
    $ship = get next key: table=$shipsBeingScanned key=$ship
  end
  
  endsub
  
  * ==============================
  
  sub.recallDrone:
  START $drone -> command COMMAND_CARRIER_RETURN : arg1=null, arg2=null, arg3=null, arg4=null
  remove key $ship from table $shipsBeingScanned
  $ship = get next key: table=$shipsBeingScanned key=null
  endsub
  * ===
  return null
]]>
</sourceplaintext>
