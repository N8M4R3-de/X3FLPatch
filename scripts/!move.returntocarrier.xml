<script>
<name>!move.returntocarrier</name>
<version>5</version>
<engineversion>74</engineversion>
<description>return to home base</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  $homebase = [THIS] ->get carrier
  [THIS] ->set destination to $homebase
  
  while [TRUE]
@   = wait 1000 ms
    
    $homebase = [THIS] ->get carrier
    
    skip if $homebase -> exists
      break
    skip if $homebase -> is docking possible of [THIS]
      break
    
    do if [DOCKEDAT] == $homebase
      break
    
    if not [THIS] -> is in same sector as $homebase
@     $ret = [THIS] -> call script !move.movetosector :  sector=$homebase
      if $ret == FLRET_NOPATH
        return $ret
      end
    end
    
    $current.carrier = [THIS] ->get carrier
    while $homebase == $current.carrier
      skip if $homebase -> exists
        break
      
      if [DOCKEDAT] == $homebase
        break
      end
      
      skip if [THIS] -> is in same sector as $current.carrier
        break
      
      if [THIS] -> is docking allowed at $homebase
@       = [THIS] -> call script !move.dockingcomputer :  Target=$homebase
      else
@       = [THIS] -> move around 60000 ms
      end
@     = wait randomly from 100 to 200 ms
      $current.carrier = [THIS] ->get carrier
    end
  end
  
  [THIS] ->set destination to null
  return null
]]>
</sourceplaintext>
