<description>Check if target is stationary for repair via ship repair laser</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  do if [THIS] -> is of class Station
    return [TRUE]
  do if [THIS] -> is of class Gate
    return [TRUE]
  if [THIS] -> is of class Ship
    if [THIS] -> is stationary flagged
      return [TRUE]
    else if not [THIS] -> get current max speed
      return [TRUE]
    end
  end
  return [FALSE]
]]>
</sourceplaintext>
