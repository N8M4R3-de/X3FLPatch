<script>
<name>!move.waitforrepair</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Interrupt to stop ship while being repaired.</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  * Move for a bit in case we're near a station
  do if [THIS] -> is in active sector
@   = [THIS] -> move around 10000 ms
  while [TRUE]
    $hull = [THIS] -> get hull percent
    skip if $hull < 100
      break
@   = wait randomly from 4000 to 7000 ms
    $repairers = [THIS] -> get local variable: name='ships.repairers'
    
@   = [THIS] -> call script plugin.jj.lib.log.object :  prepend='Waiting for repair loop.'  logFile=9898
    
    if $repairers
      $i = size of array $repairers
      write to log file #9898  append=[TRUE]  printf: fmt='ships.repairers: %s', $i, null, null, null, null
      while $i
        dec $i = 
        $repairer = $repairers[$i]
        if not $repairer -> exists
          remove element from array $repairers at index $i
          continue
        end
        $command = $repairer -> get command
        skip if $command == COMMAND_REPAIR_TARGET
          remove element from array $repairers at index $i
      end
      do if size of array $repairers
        continue
    end
    
    $m7ds = [THIS] -> get local variable: name='ships.repairers.m7d'
    skip if $m7ds
      break
    $i = size of array $m7ds
    write to log file #9898  append=[TRUE]  printf: fmt='ships.repairers.m7d: %s', $i, null, null, null, null
    skip if $i
      break
    while $i
      dec $i = 
      $m7d = $m7ds[$i]
      if not $m7d -> exists
        remove element from array $m7ds at index $i
        continue
      end
      $command = $m7d -> get command
      if not $command == COMMAND_DRONE_REPAIR_OBJECT
        remove element from array $m7ds at index $i
        continue
      end
      $target = $m7d -> get command target
      if not $target == [THIS]
        remove element from array $m7ds at index $i
        continue
      end
      $drones = $m7d ->get managed ships: role=Drone
      skip if size of array $drones
        remove element from array $m7ds at index $i
    end
  end
  
  [THIS] ->set local variable: name='ships.repairers' value=null
  [THIS] ->set local variable: name='ships.repairers.m7d' value=null
  [THIS] ->remove secondary signal: signal=SIGNAL_REPAIRED, name='Repair.Signal'
@ = [THIS] -> call script plugin.jj.lib.log.object :  prepend='Wait for repair finished'  logFile=9898
  return null
]]>
</sourceplaintext>
