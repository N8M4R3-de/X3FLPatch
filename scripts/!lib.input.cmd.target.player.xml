<script>
<name>!lib.input.cmd.target.player</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Library: Command menu</description>
<arguments>
<argument index="1" name="a.cmd" type="Object Command" desc="Command" />
<argument index="2" name="a.ships" type="Var/Boolean" desc="Ships" />
<argument index="3" name="a.stationos" type="Var/Boolean" desc="a.stations" />
</arguments>
<sourceplaintext>
<![CDATA[
  $pageid = 6020
  
  $drone.vol = $DRONE.SIZE * $drones
  $sub = change datatype[$a.cmd] to DATATYPE_INT
  
  $aim = null
  $check.aim = get player tracking aim
  if $check.aim -> exists
    if $a.ships
      if $check.aim -> is of class Ship
        $aim = $check.aim
      end
    end
    if $a.stationos
      if $check.aim -> is of class Station
        $aim = $check.aim
      end
    end
  end
  
  do if $aim == [THIS]
    $aim = null
  
  if $aim -> exists
    $aim.owner = $aim -> get owner race
    skip if $aim.owner == Player
      $aim = null
  end
  
  if $a.cmd == COMMAND_DRONE_REPAIR_OBJECT
    
    $shipFlags = [Find.Nearest] | [Find.Multiple]
    $nearest = find ship: sector=[SECTOR] class or type=Moveable Ship race=Player flags=$shipFlags refobj=[THIS] maxdist=null maxnum=20 refpos=null
    if $nearest
      $nearest = reverse array $nearest
      $i = size of array $nearest
      while $i
        dec $i = 
        $ship = $nearest[$i]
        if not $ship -> is of class Special Drone
          $hull = $ship -> get hull percent
          if $hull < 100
            $nearest = $ship
            break
          end
        end
      end
    end
    
    $nearest.station = find station: sector=[SECTOR] class or type=Station race=Player flags=$shipFlags refobj=[THIS] maxdist=null maxnum=20 refpos=null
    if $nearest.station
      $nearest.station = reverse array $nearest.station
      $i = size of array $nearest.station
      while $i
        dec $i = 
        $station = $nearest.station[$i]
        $hull = $station -> get hull percent
        if $hull < 100
          $nearest.station = $station
          break
        end
      end
    end
  else
    $nearest = find ship: sector=[SECTOR] class or type=Moveable Ship race=Player flags=[Find.Nearest] refobj=[THIS] maxdist=null maxnum=20 refpos=null
    $nearest.station = find station: sector=[SECTOR] class or type=Station race=Player flags=[Find.Nearest] refobj=[THIS] maxdist=null maxnum=null refpos=null
  end
  
  skip if $nearest != $aim
    $nearest = null
  
  skip if $nearest.station != $aim
    $nearest.station = null
  
  $menu = create custom menu array
  $info = read text: page=2022 id=$sub
  add custom menu info line to array $menu: text=$info
  
  if $aim -> exists
    $text = sprintf: pageid=$pageid textid=201, $aim, null, null, null, null
    add custom menu item to array $menu: text=$text returnvalue=$aim
  end
  if $a.ships
    if $nearest -> exists
      $text = sprintf: pageid=$pageid textid=237, $nearest, null, null, null, null
      add custom menu item to array $menu: text=$text returnvalue=$nearest
    end
  end
  if $a.stationos
    if $nearest.station -> exists
      $text = sprintf: pageid=$pageid textid=238, $nearest.station, null, null, null, null
      add custom menu item to array $menu: text=$text returnvalue=$nearest.station
    end
    
    if [HOMEBASE] -> exists
      $homebase = [HOMEBASE] -> get homebase
    end
    
    if $homebase -> exists
      if $homebase != $aim
        if $homebase != $nearest.station
          $text = sprintf: pageid=$pageid textid=240, $homebase, null, null, null, null
          add custom menu item to array $menu: text=$text returnvalue=$homebase
        end
      end
    end
  end
  
  if $a.ships
    $text = read text: page=$pageid id=216
    add custom menu item to array $menu: text=$text returnvalue=Ship
  end
  if $a.stationos
    $text = read text: page=$pageid id=239
    add custom menu item to array $menu: text=$text returnvalue=Station
  end
  
  return $menu
]]>
</sourceplaintext>
