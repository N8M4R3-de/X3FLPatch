<script>
<name>!ship.signal.dronecmdnone</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Ship Signal: Command None - Drone Carrier</description>
<arguments>
<argument index="1" name="a.cmd" type="Object Command" desc="Command" />
</arguments>
<sourceplaintext>
<![CDATA[
  $allCmds = get all commands: submenu=[CmdMenu.Drone]
  $drone.cmds = table alloc
  if $allCmds
    $i = size of array $allCmds
    while $i
      dec $i = 
      $cmd.array = $allCmds[$i]
      if is datatype[ $cmd.array ] == DATATYPE_ARRAY
        $j = size of array $cmd.array
        while $j
          dec $j = 
          $cmd = $cmd.array[$j]
          $drone.cmds[$cmd] = [TRUE]
        end
      else
        $drone.cmds[$cmd.array] = [TRUE]
      end
    end
  end
  if $drone.cmds[$a.cmd]
    $drones = [THIS] ->get managed ships: role=Drone
    if $drones
      $i = size of array $drones
      while $i
        dec $i = 
        $d = $drones[$i]
@       = $d -> call script plugin.jj.lib.log.object :  prepend='Command None from Signal_none'  logFile=1986
        START $d -> command COMMAND_NONE : arg1=null, arg2=null, arg3=null, arg4=null
      end
    end
  end
  
  $signalKilled = [THIS] -> get local variable: name='signal_killed'
  do if $signalKilled == [TRUE]
@   = [THIS] -> call script !ship.signal.killed.m7d : 
  return null
]]>
</sourceplaintext>
