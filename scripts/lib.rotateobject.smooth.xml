<script>
<name>lib.rotateobject.smooth</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Smoothly rotate an object towards an angle</description>
<arguments>
<argument index="1" name="alpha" type="Var/Number" desc="" />
<argument index="2" name="beta" type="Var/Number" desc="" />
<argument index="3" name="gamma" type="Var/Number" desc="" />
</arguments>
<sourceplaintext>
<![CDATA[
  $steeringA = [THIS] ->get current steering alpha
  skip if $steeringA
    return null
  $steeringB = [THIS] ->get current steering beta
  $steeringC = [THIS] ->get current steering gamma
  $steering = get minimum, $steeringA, $steeringB, $steeringC, $steeringA, $steeringB
  * $steering = $steering * 2 / 3
  * assume 60fps - 16.67ms per frame
  $wait = 16
  $rotPerTickMax = $steering * $wait / 1000
  $diffBiggest = 0
  
  $alphaCurrent = [THIS] -> get rot alpha
  $diff = $alpha - $alphaCurrent
  gosub sub.CalcDiffs
  $diffAlpha = $diff
  
  $betaCurrent = [THIS] -> get rot beta
  $diff = $beta - $betaCurrent
  gosub sub.CalcDiffs
  $diffBeta = $diff
  
  $gammaCurrent = [THIS] -> get rot gamma
  $diff = $gamma - $gammaCurrent
  gosub sub.CalcDiffs
  $diffGamma = $diff
  
  $ticks = $diffBiggest / $rotPerTickMax
  $rotPerTickAlpha = $diffAlpha / $ticks
  $rotPerTickBeta = $diffBeta / $ticks
  $rotPerTickGamma = $diffGamma / $ticks
  
  while $ticks
    dec $ticks = 
    $current = $alphaCurrent + $rotPerTickAlpha
    gosub sub.BoundRotToCircle
    $alphaCurrent = $current
    $current = $betaCurrent + $rotPerTickBeta
    gosub sub.BoundRotToCircle
    $betaCurrent = $current
    $current = $gammaCurrent + $rotPerTickGamma
    gosub sub.BoundRotToCircle
    $gammaCurrent = $current
    [THIS] ->set rotation: alpha=$alphaCurrent beta=$betaCurrent gamma=$gammaCurrent
@   = wait $wait ms
  end
  [THIS] ->set rotation: alpha=$alpha beta=$beta gamma=$gamma
  
  return null
  * ============
  sub.CalcDiffs:
  if $diff > 32768
    $diff = $diff - 65536
  else if $diff < -32768
    $diff = $diff + 65536
  end
  $diffABS = get absolute value: $diff
  $diffBiggest = get maximum, $diffABS, $diffBiggest, 0, 0, 0
  endsub
  * ============
  sub.BoundRotToCircle:
  do if $current > 65536
    $current = $current - 65536
  do if $current < 0
    $current = $current + 65536
  endsub
  
  return null
]]>
</sourceplaintext>
